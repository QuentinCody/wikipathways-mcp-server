{
  "name": "@bio-mcp/shared",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "default": "./dist/tools/*.js"
    },
    "./codemode/*": {
      "types": "./dist/codemode/*.d.ts",
      "default": "./dist/codemode/*.js"
    },
    "./staging/*": {
      "types": "./dist/staging/*.d.ts",
      "default": "./dist/staging/*.js"
    },
    "./entities/*": {
      "types": "./dist/entities/*.d.ts",
      "default": "./dist/entities/*.js"
    },
    "./http/*": {
      "types": "./dist/http/*.d.ts",
      "default": "./dist/http/*.js"
    },
    "./charting/*": {
      "types": "./dist/charting/*.d.ts",
      "default": "./dist/charting/*.js"
    },
    "./filesystem/*": {
      "types": "./dist/filesystem/*.d.ts",
      "default": "./dist/filesystem/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "biome lint --diagnostic-level=error src",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "pnpm run type-check",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@bio-mcp/syntaqlite-worker": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@cloudflare/workers-types": "^4.20260203.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@cloudflare/codemode": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/codemode": {
      "optional": true
    }
  }
}
